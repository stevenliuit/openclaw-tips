<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="<%- url_for('/favicon.ico') %>">
  <title>文章归档 - <%= config.title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <%- css('css/custom.css') %>
</head>
<body>
  <header class="header">
    <div class="container header-inner">
      <a href="<%- url_for('/') %>" class="logo">
        <div class="logo-icon">🤖</div>
        <span class="logo-text"><%= config.title %></span>
      </a>
      <nav class="nav">
        <a href="<%- url_for('/') %>" class="nav-link">首页</a>
        <div class="nav-group">
          <span class="nav-link">分类 ▾</span>
          <div class="group-menu">
            <div class="group-col"><h4>教程</h4><a href="/categories/教程/">教程</a></div>
            <div class="group-col"><h4>技能</h4><a href="/categories/Skills开发/">Skills</a></div>
            <div class="group-col"><h4>自动化</h4><a href="/categories/自动化/">自动化</a></div>
            <div class="group-col"><h4>安全</h4><a href="/categories/安全配置/">安全</a></div>
          </div>
        </div>
        <a href="<%- url_for('/tags') %>" class="nav-link">标签</a>
        <a href="<%- url_for('/archives') %>" class="nav-link">归档</a>
      </nav>
    </div>
  </header>

  <div class="page-layout">
    <aside class="sidebar">
      <h3 class="sidebar-title">📅 文章归档</h3>
      <div class="sidebar-cats">
        <% 
          var years = {};
          site.posts.forEach(function(post){
            var y = date(post.date, 'YYYY');
            if(!years[y]) years[y] = 0;
            years[y]++;
          });
          Object.keys(years).sort().reverse().forEach(function(y){ 
        %>
          <a href="<%- url_for('/archives') %>#<%= y %>" class="sidebar-cat"><%= y %> 年 (<%= years[y] %>)</a>
        <% }); %>
      </div>
    </aside>

    <main class="main-content">
      <div class="page-header">
        <h1 class="page-title">📅 文章归档 <span class="page-count">(<%= site.posts.length %>)</span></h1>
      </div>

      <% 
        var posts = site.posts.sort('date', -1);
        var currentYear = '';
        var count = 0;
        posts.forEach(function(post){
          var year = date(post.date, 'YYYY');
          if(year !== currentYear){ 
            if(count > 0){
      %>
        </div>
      <%      } count++; %>
        <div class="archive-group" id="<%= year %>">
          <h2 class="archive-year"><%= year %> 年</h2>
          <div class="archive-list">
      <%    currentYear = year; } %>
            <a href="<%- url_for(post.path) %>" class="archive-item">
              <span class="archive-date"><%- date(post.date, 'MM-DD') %></span>
              <span class="archive-title"><%- post.title %></span>
            </a>
        <% }); %>
          </div>
        </div>
    </main>
  </div>

  <footer class="footer">
    <div class="container footer-grid">
      <div class="footer-col"><div class="footer-logo">🤖 <%= config.title %></div><p><%= config.description %></p></div>
      <div class="footer-col"><h4>链接</h4><a href="/">首页</a><a href="/categories">分类</a><a href="/tags">标签</a></div>
      <div class="footer-col"><h4>资源</h4><a href="https://docs.openclaw.ai">文档</a></div>
    </div>
    <div class="footer-copy">© 2024 <%= config.title %></div>
  </footer>
</body>
</html>
