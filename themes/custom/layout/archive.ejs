<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="<%- url_for('/favicon.ico') %>">
  <title>文章归档 - <%= config.title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <%- css('css/custom.css') %>
</head>
<body>
  <header class="header">
    <div class="container header-inner">
      <a href="<%- url_for('/') %>" class="logo">
        <div class="logo-icon">🤖</div>
        <span class="logo-text"><%= config.title %></span>
      </a>
      <nav class="nav">
        <a href="<%- url_for('/') %>" class="nav-link">首页</a>
        <div class="nav-group">
          <span class="nav-link">分类 ▾</span>
          <div class="group-menu">
            <div class="group-col"><h4>教程</h4><a href="/categories/教程/">教程</a></div>
            <div class="group-col"><h4>技能</h4><a href="/categories/Skills开发/">Skills</a></div>
            <div class="group-col"><h4>自动化</h4><a href="/categories/自动化/">自动化</a></div>
            <div class="group-col"><h4>安全</h4><a href="/categories/安全配置/">安全</a></div>
          </div>
        </div>
        <a href="<%- url_for('/tags') %>" class="nav-link">标签</a>
        <a href="<%- url_for('/archives') %>" class="nav-link">归档</a>
      </nav>
    </div>
  </header>

  <section class="hero" style="padding:40px 24px">
    <div class="container">
      <h1 class="page-title"><span>📅</span> 文章归档</h1>
    </div>
  </section>

  <section class="articles">
    <div class="container">
      <div class="timeline">
        <% 
          var posts = site.posts.sort('date', -1);
          var currentYear = '';
          posts.forEach(function(post){
            var year = date(post.date, 'YYYY');
            if(year !== currentYear){
              currentYear = year;
        %>
          <div class="timeline-year"><%= year %> 年</div>
        <% } %>
          <a href="<%- url_for(post.path) %>" class="timeline-item">
            <span class="timeline-date"><%- date(post.date, 'MM-DD') %></span>
            <span class="timeline-title"><%- post.title %></span>
          </a>
        <% }); %>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container footer-grid">
      <div class="footer-col"><div class="footer-logo">🤖 <%= config.title %></div><p><%= config.description %></p></div>
      <div class="footer-col"><h4>链接</h4><a href="/">首页</a><a href="/categories">分类</a><a href="/tags">标签</a></div>
      <div class="footer-col"><h4>资源</h4><a href="https://docs.openclaw.ai">文档</a></div>
    </div>
    <div class="footer-copy">© 2024 <%= config.title %></div>
  </footer>
</body>
</html>
