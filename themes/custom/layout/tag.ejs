<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="<%- url_for('/favicon.ico') %>">
  <title>标签云 - <%= config.title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono&display=swap" rel="stylesheet">
  <%- css('css/custom.css') %>
</head>
<body>
  <header class="header">
    <div class="container header-inner">
      <a href="<%- url_for('/') %>" class="logo">
        <div class="logo-icon">🤖</div>
        <span class="logo-text"><%= config.title %></span>
      </a>
      <nav class="nav" style="">
        <a href="<%- url_for('/') %>" class="nav-link">首页</a>
        <a href="<%- url_for('/categories') %>" class="nav-link">分类</a>
        <a href="<%- url_for('/tags') %>" class="nav-link">标签云</a>
        <a href="<%- url_for('/archives') %>" class="nav-link">归档</a>
      </nav>
    </div>
  </header>

  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container">
      <h1 class="hero-title"><span>🏷️</span> 标签云</h1>
      <p class="hero-subtitle">共 <%= site.tags.length %> 个标签</p>
    </div>
  </section>

  <section class="tech-tags">
    <div class="container">
      <div class="tag-grid">
        <% 
          var allTags = [];
          var tagCounts = {};
          site.posts.forEach(function(post){
            if(post.tags){
              post.tags.forEach(function(tag){
                var name = tag.name;
                if(!tagCounts[name]){
                  tagCounts[name] = 0;
                  allTags.push(name);
                }
                tagCounts[name]++;
              });
            }
          });
          allTags.sort();
        %>
        <% allTags.forEach(function(tag){ %>
          <a href="<%- url_for('/tags/' + tag) %>" class="tech-tag" style="--i:<%= Math.floor(Math.random() * 20) %>">
            <span class="tag-name"><%- tag %></span>
            <span class="tag-num"><%- tagCounts[tag] %></span>
          </a>
        <% }); %>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container footer-grid">
      <div class="footer-col"><div class="footer-logo">🤖 <%= config.title %></div><p><%= config.description %></p></div>
      <div class="footer-col"><h4>链接</h4><a href="/">首页</a><a href="/categories">分类</a><a href="/tags">标签</a></div>
      <div class="footer-col"><h4>资源</h4><a href="https://docs.openclaw.ai">文档</a></div>
    </div>
    <div class="footer-copy">© 2024 <%= config.title %></div>
  </footer>
</body>
</html>
