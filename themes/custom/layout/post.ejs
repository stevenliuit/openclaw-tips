<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="<%- url_for('/favicon.ico') %>">
  <title><%= page.title %> - <%= config.title %></title>
  <meta name="description" content="<%= page.description || page.excerpt || '' %>">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono&display=swap" rel="stylesheet">
  <%- css('css/custom.css') %>
  <style>
    .post-header{text-align:center;padding:50px 24px 30px;background:linear-gradient(180deg,#EEF2FF 0%,var(--bg) 100%)}
    .post-meta{display:flex;justify-content:center;gap:20px;margin-bottom:16px;font-size:14px;color:var(--text2)}
    .post-title{font-size:32px;font-weight:700;margin-bottom:16px;line-height:1.3}
    .post-cats{display:flex;justify-content:center;gap:10px;margin-bottom:20px}
    .post-cats a{padding:6px 16px;background:var(--card);border:1px solid var(--b);border-radius:20px;font-size:13px;color:var(--text2)}
    .post-cats a:hover{background:var(--c);border-color:var(--c);color:#FFF}
    .post-content{max-width:800px;margin:0 auto;padding:0 24px 60px}
    .post-body{background:var(--card);padding:40px;border-radius:var(--r);box-shadow:var(--sh)}
    .post-body h2{font-size:22px;margin:32px 0 16px;padding-bottom:10px;border-bottom:1px solid var(--b)}
    .post-body h3{font-size:18px;margin:24px 0 12px}
    .post-body p{margin-bottom:16px;line-height:1.8}
    .post-body ul,.post-body ol{margin:0 0 16px 24px}
    .post-body li{margin-bottom:8px}
    .post-body pre{background:#1E293B;color:#E2E8F0;padding:20px;border-radius:12px;overflow-x:auto;margin:20px 0;font-family:'JetBrains Mono',monospace;font-size:14px;line-height:1.6}
    .post-body code{background:#F1F5F9;padding:2px 8px;border-radius:4px;font-family:'JetBrains Mono',monospace;font-size:13px}
    .post-body pre code{background:none;padding:0;color:inherit}
    .post-body a{color:var(--c);text-decoration:underline}
    .post-body img{max-width:100%;border-radius:var(--r)}
    .post-tags{margin-top:32px;padding-top:24px;border-top:1px solid var(--b)}
    .post-tags span{font-size:14px;color:var(--text2);margin-right:8px}
    .post-tags a{display:inline-block;padding:4px 12px;background:#EEF2FF;color:var(--c);border-radius:16px;font-size:13px;margin:4px}
  </style>
</head>
<body>
  <header class="header">
    <div class="container header-inner">
      <a href="<%- url_for('/') %>" class="logo">
        <div class="logo-icon">🤖</div>
        <span class="logo-text"><%= config.title %></span>
      </a>
      <nav class="nav">
        <a href="<%- url_for('/') %>" class="nav-link">首页</a>
        <a href="<%- url_for('/categories') %>" class="nav-link">分类</a>
        <a href="<%- url_for('/tags') %>" class="nav-link">标签云</a>
        <a href="<%- url_for('/archives') %>" class="nav-link">归档</a>
      </nav>
    </div>
  </header>

  <article>
    <div class="post-header">
      <div class="post-meta">
        <span>📅 <%- date(page.date, 'YYYY-MM-DD') %></span>
        <span>👁 <%- page.views || Math.floor(Math.random()*1000) %> 阅读</span>
      </div>
      <h1 class="post-title"><%- page.title %></h1>
      <div class="post-cats">
        <% if (page.categories && page.categories.length) { %>
          <% page.categories.forEach(function(cat){ %>
            <a href="<%- url_for('/categories/' + cat.name) %>"><%- cat.name %></a>
          <% }); %>
        <% } else { %>
          <a href="<%- url_for('/categories/教程') %>">教程</a>
        <% } %>
      </div>
    </div>
    
    <div class="post-content">
      <div class="post-body">
        <%- page.content %>
        
        <% if (page.tags && page.tags.length) { %>
          <div class="post-tags">
            <span>🏷️ 标签:</span>
            <% page.tags.forEach(function(tag){ %>
              <a href="<%- url_for('/tags/' + tag.name) %>"><%- tag.name %></a>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>
  </article>

  <footer class="footer">
    <div class="container footer-grid">
      <div class="footer-col"><div class="footer-logo">🤖 <%= config.title %></div><p><%= config.description %></p></div>
      <div class="footer-col"><h4>快速链接</h4><a href="/">首页</a><a href="/categories">分类</a><a href="/tags">标签</a><a href="/archives">归档</a></div>
      <div class="footer-col"><h4>资源</h4><a href="https://docs.openclaw.ai">官方文档</a><a href="https://github.com/openclaw/openclaw">GitHub</a></div>
    </div>
    <div class="footer-copy">© 2024 <%= config.title %></div>
  </footer>
</body>
</html>
