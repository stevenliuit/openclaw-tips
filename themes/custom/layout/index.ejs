<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/x-icon" href="<%- url_for('/favicon.ico') %>">
  <title><%= config.title %></title>
  <meta name="description" content="<%= config.description %>">
  <link href="https://fonts.googleapis.com/css2?family=Calistoga&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <%- css('css/custom.css') %>
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="container header-inner">
      <a href="<%- url_for('/') %>" class="logo">
        <div class="logo-icon">🤖</div>
        <span class="logo-text"><%= config.title %></span>
      </a>
      <nav class="nav">
        <a href="<%- url_for('/') %>" class="nav-link">🏠 首页</a>
        <div class="nav-dropdown">
          <span class="nav-link">📁 分类 ▾</span>
          <div class="dropdown-menu">
            <a href="<%- url_for('/categories/教程') %>">📚 教程</a>
            <a href="<%- url_for('/categories/技能') %>">✨ 技能</a>
            <a href="<%- url_for('/categories/安全') %>">🔒 安全</a>
            <a href="<%- url_for('/categories/对比') %>">⚖️ 对比</a>
            <a href="<%- url_for('/categories/自动化') %>">🤖 自动化</a>
            <a href="<%- url_for('/categories/趋势') %>">🔥 趋势</a>
          </div>
        </div>
        <a href="<%- url_for('/tags') %>" class="nav-link">🏷️ 标签</a>
        <a href="<%- url_for('/archives') %>" class="nav-link">📅 归档</a>
      </nav>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container">
      <h1 class="hero-title"><span><%= config.title %></span></h1>
      <p class="hero-subtitle"><%= config.subtitle %></p>
      <div class="search-box">
        <input type="text" class="search-input" placeholder="🔍 搜索文章...">
      </div>
      <div class="stats">
        <div class="stat-card"><div class="stat-icon">📄</div><div class="stat-number">945+</div><div class="stat-label">精选文章</div></div>
        <div class="stat-card"><div class="stat-icon">📁</div><div class="stat-number">12</div><div class="stat-label">文章分类</div></div>
        <div class="stat-card"><div class="stat-icon">🔄</div><div class="stat-number">∞</div><div class="stat-label">每日更新</div></div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <div class="container">
    <div class="categories">
      <a href="<%- url_for('/') %>" class="cat-item active">🌐 全部</a>
      <a href="<%- url_for('/categories/教程') %>" class="cat-item">📚 教程</a>
      <a href="<%- url_for('/categories/技能') %>" class="cat-item">✨ 技能</a>
      <a href="<%- url_for('/categories/安全') %>" class="cat-item">🔒 安全</a>
      <a href="<%- url_for('/categories/对比') %>" class="cat-item">⚖️ 对比</a>
      <a href="<%- url_for('/categories/自动化') %>" class="cat-item">🤖 自动化</a>
      <a href="<%- url_for('/categories/趋势') %>" class="cat-item">🔥 趋势</a>
    </div>
  </div>

  <!-- Articles -->
  <section class="articles-section">
    <div class="container">
      <h2 class="section-title">🔥 最新文章</h2>
      <div class="articles-grid">
        <% page.posts.forEach(function(post, index){ %>
          <article class="article-card">
            <a href="<%- url_for(post.path) %>" class="article-link">
              <div class="article-img" style="<%- getGradient(index) %>"><span class="article-emoji"><%- getEmoji(index) %></span></div>
              <div class="article-body">
                <div class="article-meta">
                  <span class="article-cat" style="color:<%- getCatColor(post.category) %>">● <%- post.category || '教程' %></span>
                  <span class="article-date"><%- date(post.date, 'YYYY-MM-DD') %></span>
                </div>
                <h3 class="article-title"><%- post.title %></h3>
                <p class="article-desc"><%- post.description || post.excerpt || '点击查看全文...' %></p>
              </div>
            </a>
          </article>
        <% }); %>
      </div>
      <% if (page.total > 1) { %>
        <div class="pagination">
          <% for (var i = 1; i <= page.total; i++) { %>
            <a href="<%- url_for('page/' + i) %>" class="page-num <%= page.current === i ? 'curr' : '' %>"><%- i %></a>
          <% } %>
        </div>
      <% } %>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="newsletter">
    <div class="container">
      <div class="newsletter-box">
        <h3>📧 订阅更新</h3>
        <p>获取最新 AI 教程和 OpenClaw 技巧</p>
        <form><input type="email" placeholder="输入邮箱"><button>订阅</button></form>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-left">
        <div class="footer-logo">🤖 <span><%= config.title %></span></div>
        <p><%= config.description %></p>
      </div>
      <div class="footer-links">
        <div><h4>快速链接</h4><a href="/">首页</a><a href="/categories">分类</a><a href="/tags">标签</a></div>
        <div><h4>资源</h4><a href="https://docs.openclaw.ai">官方文档</a><a href="https://github.com/openclaw/openclaw">GitHub</a></div>
      </div>
    </div>
    <div class="footer-bottom">© 2024 <%= config.title %> · 由 OpenClaw 驱动</div>
  </footer>
</body>
</html>

<%
function getGradient(i) {
  const g = ['background:linear-gradient(135deg,#667eea,#764ba2)','background:linear-gradient(135deg,#f093fb,#f5576c)','background:linear-gradient(135deg,#4facfe,#00f2fe)','background:linear-gradient(135deg,#43e97b,#38f9d7)','background:linear-gradient(135deg,#fa709a,#fee140)','background:linear-gradient(135deg,#a8edea,#fed6e3)'];
  return g[i % g.length];
}
function getEmoji(i) {
  const e = ['🤖','🧠','✨','💡','🚀','⚡','🔧','🎯','💻','🎨','📚','🔒'];
  return e[i % e.length];
}
function getCatColor(cat) {
  const c = {'教程':'#0052FF','技能':'#7C3AED','安全':'#DC2626','对比':'#059669','自动化':'#D97706','趋势':'#EC4899'};
  return c[cat] || '#0052FF';
}
%>
